# Copy this file to .env and fill in your credentials.
# .env is git-ignored and will never be committed.

LOBSTER_API_KEY=your_api_key_here
LOBSTER_API_SECRET=your_api_secret_here

# Set to "true" to use the pilot/dev endpoint (dev.lobsterdata.com)
# Set to "false" for the production endpoint (lobsterdata.com)
LOBSTER_IS_PILOT=true